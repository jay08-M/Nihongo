<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A1A"
    android:padding="20dp"
    tools:context=".BasicAlphabetActivity">

    <!-- Header Area -->
    <TextView
        android:id="@+id/stylizedNumber"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:includeFontPadding="false"
        android:text="学習"
        android:textColor="#3E6868"
        android:textSize="60sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/inspirationLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginTop="8dp"
        android:text="Alphabet"
        android:textColor="#5E5E5E"
        android:textSize="14sp"
        app:layout_constraintStart_toEndOf="@id/stylizedNumber"
        app:layout_constraintTop_toTopOf="@id/stylizedNumber" />

    <TextView
        android:id="@+id/mainTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:width="200dp"
        android:text="Writing System (Kana)"
        android:textColor="#FFFFFF"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="@id/inspirationLabel"
        app:layout_constraintTop_toBottomOf="@id/inspirationLabel" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigation"
        app:layout_constraintTop_toBottomOf="@id/stylizedNumber">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:text="Select a category to practice:"
                android:textColor="#5E5E5E"
                android:textSize="14sp" />

            <!-- Hiragana Banner -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/hiraganaBanner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:background="@drawable/teal_rounded_bg"
                android:padding="20dp">

                <TextView
                    android:id="@+id/hiraganaTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hiragana"
                    android:textColor="#FFFFFF"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Master the basic 46 characters."
                    android:textColor="#1A1A1A"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toStartOf="@+id/btnOpenHiragana"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/hiraganaTitle" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnOpenHiragana"
                    android:layout_width="80dp"
                    android:layout_height="32dp"
                    android:background="@drawable/button_radius_8"
                    android:text="START"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Katakana Banner -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/katakanaBanner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:background="@drawable/tan_rounded_bg"
                android:padding="20dp">

                <TextView
                    android:id="@+id/katakanaTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Katakana"
                    android:textColor="#1A1A1A"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Practice foreign loan words."
                    android:textColor="#5E5E5E"
                    android:textSize="12sp"
                    app:layout_constraintEnd_toStartOf="@+id/btnOpenKatakana"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/katakanaTitle" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnOpenKatakana"
                    android:layout_width="80dp"
                    android:layout_height="32dp"
                    android:background="@drawable/button_radius_8"
                    android:text="START"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Kanji Banner -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/kanjiBanner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/red_rounded_bg"
                android:padding="20dp">

                <TextView
                    android:id="@+id/kanjiTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Kanji"
                    android:textColor="#FFFFFF"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Learn complex logographic characters."
                    android:textColor="#1A1A1A"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toStartOf="@+id/btnOpenKanji"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/kanjiTitle" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnOpenKanji"
                    android:layout_width="80dp"
                    android:layout_height="32dp"
                    android:background="@drawable/button_radius_8"
                    android:text="START"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Navigation -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1A1A1A"
        app:itemIconTint="#C1AB85"
        app:itemTextColor="#C1AB85"
        app:labelVisibilityMode="labeled"
        app:layout_constraintBottom_toBottomOf="parent"
        app:menu="@menu/bottom_nav_menu" />

</androidx.constraintlayout.widget.ConstraintLayout>
